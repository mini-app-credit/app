# Application (runtime identity: NAME@NODE_ENV → e.g. mini-credit@development)
NAME=mini-credit
NODE_ENV=development
LEVEL=debug
# Database (Postgres database name is minicredit — no hyphen, matches POSTGRES_DB in compose).
# In Docker, host must be the compose service name (mini-credit-postgres), not localhost.
DATABASE_WRITE_URL=postgresql://postgres:postgres@mini-credit-postgres:5432/minicredit
DATABASE_READ_REPLICA_URLS=postgresql://postgres:postgres@mini-credit-postgres:5432/minicredit

# S3 (AWS; set bucket name and credentials)
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_BUCKET_NAME=minicredit-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=false

# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Redis
REDIS_HOST=mini-credit-redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TLS=false

# NATS
NATS_SERVERS=nats://mini-credit-nats:4222

# JWT
JWT_SECRET=dev-jwt-secret
JWT_EXPIRES_IN=15m

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=0.0.1
SENTRY_SEND_DEFAULT_PII=true
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_DEBUG=false
SENTRY_ENABLED=false

# Amplitude
AMPLITUDE_API_KEY=

# Rate Limiting
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX_REQUESTS=100
RATE_LIMIT_AUTH_SENSITIVE_WINDOW_MS=60000
RATE_LIMIT_AUTH_SENSITIVE_MAX_REQUESTS=10
RATE_LIMIT_AUTHENTICATED_WINDOW_MS=60000
RATE_LIMIT_AUTHENTICATED_MAX_REQUESTS=300

# Channels OAuth
CREDENTIALS_ENCRYPTION_KEY=dev-encryption-key-32-chars-long!
OAUTH_INSTAGRAM_CLIENT_ID=
OAUTH_INSTAGRAM_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_YOUTUBE_CLIENT_ID=263433568346-hamuq6d439ortr1ln89m3610s0hqeker.apps.googleusercontent.com
OAUTH_YOUTUBE_CLIENT_SECRET=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
OAUTH_LINKEDIN_CLIENT_ID=
OAUTH_LINKEDIN_CLIENT_SECRET=

# Templates Service
TEMPLATES_SERVICE_URL=http://mini-credit-templates:3100

# Internal API Token (scheduler)
INTERNAL_API_TOKEN=dev-internal-token

# Google Gemini (optional — AI advisory summary on submitted applications)
GEMINI_API_KEY=AIzaSyBHjC5Z1zhX9tHs4JFqUExzGVDF3JbmCkk
GEMINI_MODEL=gemini-3-flash-preview

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mini-credit.local
